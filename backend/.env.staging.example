# ── Staging Environment ────────────────────────────────────────────
# Copy this file to .env when running the staging environment.
# Railway injects DATABASE_URL automatically — no need to set it manually there.

APP_ENV=staging
ENVIRONMENT=staging
DJANGO_SETTINGS_MODULE=erickshaw.settings.staging
DEBUG=False

# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=replace-with-strong-staging-secret

# Database: Railway injects DATABASE_URL automatically in Railway environments.
# For local staging simulation, set STAGING_DATABASE_URL instead:
STAGING_DATABASE_URL=postgres://staging_user:staging_password@staging-db-host:5432/erikshaw_staging_db

# Hosts
ALLOWED_HOSTS=staging-api.erikshawdekho.com
CORS_ALLOWED_ORIGINS=https://staging.erikshawdekho.com

# Seeding gate — Railway CI sets this to "true" in deploy-staging.yml
ALLOW_STAGING_SEED=false

# Error tracking (optional)
SENTRY_DSN=

# Email (optional for staging — use console backend locally)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Platform branding
PLATFORM_NAME=eRickshawDekho
PLATFORM_TAGLINE=Bharosemand Platform
PLATFORM_URL=https://staging.erikshawdekho.com
PLATFORM_TEAM_NAME=eRickshawDekho Team
PLATFORM_NOREPLY_EMAIL=noreply@erikshawdekho.com
SUPPORT_EMAIL=support@erikshawdekho.com
SUPPORT_PHONE=+91-XXXXXXXXXX
SUPPORT_WHATSAPP=https://wa.me/91XXXXXXXXXX
